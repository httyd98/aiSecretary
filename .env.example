# SegretarioLLM — variabili d'ambiente
# Copia questo file in .env e compila con i tuoi valori reali

# PostgreSQL (Railway, Render, Supabase, ecc.)
DATABASE_URL=postgresql://user:password@localhost:5432/segretario_db

# Meta / WhatsApp Business API
# Trova questi valori su: https://developers.facebook.com/apps/<tuo-app-id>/whatsapp-business/wa-dev-console/
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxx
VERIFY_TOKEN=scegli_un_token_segreto_qualsiasi

# ID del Numero A (riceve messaggi dai clienti)
CLIENT_PHONE_NUMBER_ID=1234567890

# ID del Numero B (usato dal professionista per inviare comandi)
PROF_PHONE_NUMBER_ID=0987654321

# Numero WhatsApp del professionista (formato internazionale, senza +)
PROF_WA_ID=393331234567

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Modello Claude da usare (opzionale, default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6
